{
  "id": null,
  "uid": "safety-eye-like",
  "title": "Safety Eye Dashboard",
  "tags": ["safety-eye", "ppe"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 5,
  "refresh": "5s",
  "time": { "from": "now-90d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "video_id",
        "label": "Video",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "postgres-ds" },
        "query": "SELECT CONCAT('#', id::text, ' - ', name) AS __text, id::text AS __value FROM videos ORDER BY id DESC",
        "refresh": 2,
        "includeAll": true,
        "allValue": "0",
        "multi": false,
        "sort": 0,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Total Detections",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "targets": [{ "format": "table", "refId": "A",
        "rawSql": "SELECT COUNT(*) AS value FROM detections WHERE (${video_id} = 0 OR video_id = ${video_id})"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto", "graphMode": "none", "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 2, "type": "stat", "title": "Total Violations",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "targets": [{ "format": "table", "refId": "A",
        "rawSql": "SELECT COUNT(*) AS value FROM detections WHERE object_name ILIKE 'no-%' AND (${video_id} = 0 OR video_id = ${video_id})"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto", "graphMode": "none", "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 }] } } }
    },
    {
      "id": 3, "type": "stat", "title": "Videos Processing",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "targets": [{ "format": "table", "refId": "A",
        "rawSql": "SELECT COUNT(*) AS value FROM videos WHERE status = 'processing'"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto", "graphMode": "none", "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 4, "type": "stat", "title": "Compliance Rate",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "targets": [{ "format": "table", "refId": "A",
        "rawSql": "SELECT ROUND(100.0 * SUM(CASE WHEN object_name NOT ILIKE 'no-%' THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0), 1) AS value FROM detections WHERE (${video_id} = 0 OR video_id = ${video_id})"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto", "graphMode": "none", "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 50 }, { "color": "green", "value": 80 }] } } }
    },
    {
      "id": 17, "type": "stat", "title": "Unique People Counted",
      "description": "Confirmed unique persons via YOLOv8 tracking (stability filter: 5 frames)",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "targets": [{ "format": "table", "refId": "A",
        "rawSql": "SELECT COALESCE(SUM(unique_person_count), 0) AS value FROM videos WHERE (${video_id} = 0 OR id = ${video_id})"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto", "graphMode": "none", "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 11, "type": "stat", "title": "NO-Hardhat",
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "targets": [{ "format": "table", "refId": "A",
        "rawSql": "SELECT COUNT(*) AS value FROM detections WHERE object_name ILIKE 'NO-Hardhat' AND (${video_id} = 0 OR video_id = ${video_id})"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto", "graphMode": "none", "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }] } } }
    },
    {
      "id": 12, "type": "stat", "title": "NO-Safety Vest",
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 4 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "targets": [{ "format": "table", "refId": "A",
        "rawSql": "SELECT COUNT(*) AS value FROM detections WHERE object_name ILIKE 'NO-Safety Vest' AND (${video_id} = 0 OR video_id = ${video_id})"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto", "graphMode": "none", "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }] } } }
    },
    {
      "id": 13, "type": "stat", "title": "NO-Mask",
      "gridPos": { "h": 3, "w": 4, "x": 8, "y": 4 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "targets": [{ "format": "table", "refId": "A",
        "rawSql": "SELECT COUNT(*) AS value FROM detections WHERE object_name ILIKE 'NO-Mask' AND (${video_id} = 0 OR video_id = ${video_id})"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto", "graphMode": "none", "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }] } } }
    },
    {
      "id": 14, "type": "stat", "title": "Safety Vest",
      "gridPos": { "h": 3, "w": 4, "x": 12, "y": 4 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "targets": [{ "format": "table", "refId": "A",
        "rawSql": "SELECT COUNT(*) AS value FROM detections WHERE object_name ILIKE 'Safety Vest' AND (${video_id} = 0 OR video_id = ${video_id})"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto", "graphMode": "none", "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 15, "type": "stat", "title": "Hardhat",
      "gridPos": { "h": 3, "w": 4, "x": 16, "y": 4 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "targets": [{ "format": "table", "refId": "A",
        "rawSql": "SELECT COUNT(*) AS value FROM detections WHERE object_name ILIKE 'Hardhat' AND (${video_id} = 0 OR video_id = ${video_id})"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto", "graphMode": "none", "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 16, "type": "stat", "title": "Person",
      "gridPos": { "h": 3, "w": 4, "x": 20, "y": 4 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "targets": [{ "format": "table", "refId": "A",
        "rawSql": "SELECT COUNT(*) AS value FROM detections WHERE object_name ILIKE 'Person' AND (${video_id} = 0 OR video_id = ${video_id})"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto", "graphMode": "none", "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 5, "type": "timeseries", "title": "Detections Over Time (by class)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 7 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "targets": [{ "format": "time_series", "refId": "A",
        "rawSql": "SELECT date_trunc('second', v.upload_time + (d.timestamp * interval '1 second')) AS time, d.object_name AS metric, COUNT(*) AS value FROM detections d JOIN videos v ON v.id = d.video_id WHERE (${video_id} = 0 OR d.video_id = ${video_id}) GROUP BY 1, 2 ORDER BY 1"
      }],
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } }
    },
    {
      "id": 6, "type": "barchart", "title": "Detections By Class",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "targets": [{ "format": "table", "refId": "A",
        "rawSql": "SELECT d.object_name, COUNT(*) AS count FROM detections d WHERE (${video_id} = 0 OR d.video_id = ${video_id}) GROUP BY d.object_name ORDER BY count DESC"
      }],
      "options": { "xField": "object_name", "barWidth": 0.7, "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } }
    },
    {
      "id": 7, "type": "timeseries", "title": "Violation Rate Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "targets": [{ "format": "time_series", "refId": "A",
        "rawSql": "SELECT date_trunc('minute', v.upload_time + (d.timestamp * interval '1 second')) AS time, COUNT(*) AS value FROM detections d JOIN videos v ON v.id = d.video_id WHERE d.object_name ILIKE 'no-%' AND (${video_id} = 0 OR d.video_id = ${video_id}) GROUP BY 1 ORDER BY 1"
      }],
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "red", "mode": "fixed" }, "custom": { "drawStyle": "bars", "fillOpacity": 70 } } }
    },
    {
      "id": 9, "type": "piechart", "title": "Violation Breakdown by Type",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "targets": [{ "format": "table", "refId": "A",
        "rawSql": "SELECT d.object_name, COUNT(*) AS count FROM detections d WHERE d.object_name ILIKE 'no-%' AND (${video_id} = 0 OR d.video_id = ${video_id}) GROUP BY d.object_name ORDER BY count DESC"
      }],
      "options": { "pieType": "donut", "displayLabels": ["name", "percent"], "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "values": ["value", "percent"] } }
    },
    {
      "id": 8, "type": "table", "title": "Latest Violations",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 23 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "targets": [{ "format": "table", "refId": "A",
        "rawSql": "SELECT (v.upload_time + (d.timestamp * interval '1 second')) AS event_time, d.video_id, d.frame_id, d.object_name AS violation_type, ROUND((d.confidence * 100)::numeric, 1) AS confidence_pct FROM detections d JOIN videos v ON v.id = d.video_id WHERE d.object_name ILIKE 'no-%' AND (${video_id} = 0 OR d.video_id = ${video_id}) ORDER BY event_time DESC LIMIT 200"
      }],
      "options": { "footer": { "show": false } },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } }, "overrides": [{ "matcher": { "id": "byName", "options": "confidence_pct" }, "properties": [{ "id": "unit", "value": "percent" }] }] }
    }
  ]
}
